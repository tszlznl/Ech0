    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "vue-sonner": "^2.0.9",
    "vue-virtual-scroller": "3.0.4"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
