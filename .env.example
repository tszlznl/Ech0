# ===========================================
# Ech0 Environment Configuration
# Copy this file to .env and modify as needed
# ===========================================

# ---- Server ----
# ECH0_SERVER_PORT=6277
# ECH0_SERVER_HOST=0.0.0.0
# ECH0_SERVER_MODE=release        # debug / release

# ---- Database ----
# ECH0_DB_TYPE=sqlite
# ECH0_DB_PATH=data/ech0.db
# ECH0_DB_LOGMODE=release          # debug / release

# ---- Auth / JWT ----
# JWT_SECRET=                       # leave empty to auto-generate
# ECH0_JWT_EXPIRES=2592000          # seconds, default 30 days
# ECH0_JWT_ISSUER=ech0
# ECH0_JWT_AUDIENCE=ech0

# ---- Upload ----
# ECH0_UPLOAD_IMAGE_MAX_SIZE=20971520   # bytes, default 20MB
# ECH0_UPLOAD_AUDIO_MAX_SIZE=20971520   # bytes, default 20MB
# ECH0_UPLOAD_IMAGE_PATH=data/files/images/
# ECH0_UPLOAD_AUDIO_PATH=data/files/audios/

# ---- Storage (local) ----
# ECH0_STORAGE_MODE=local           # local / s3
# ECH0_STORAGE_DATA_ROOT=data/files

# ---- Storage (S3-compatible) ----
# ECH0_S3_ENDPOINT=
# ECH0_S3_ACCESS_KEY=
# ECH0_S3_SECRET_KEY=
# ECH0_S3_BUCKET=
# ECH0_S3_REGION=
# ECH0_S3_PROVIDER=                 # aws / r2 / minio / other
# ECH0_S3_USE_SSL=false
# ECH0_S3_CDN_URL=
# ECH0_S3_PATH_PREFIX=

# ---- Setting ----
# ECH0_SETTING_SITE_TITLE=Ech0
# ECH0_SETTING_SERVER_LOGO=/Ech0.svg
# ECH0_SETTING_SERVER_NAME=Ech0
# ECH0_SETTING_SERVER_URL=https://ech0.example.com
# ECH0_SETTING_ALLOW_REGISTER=true
# ECH0_SETTING_ICP_NUMBER=
# ECH0_SETTING_METING_API=
# ECH0_SETTING_CUSTOM_CSS=
# ECH0_SETTING_CUSTOM_JS=

# ---- Comment ----
# ECH0_COMMENT_ENABLE=false
# ECH0_COMMENT_PROVIDER=twikoo
# ECH0_COMMENT_API=
