{
  "name": "hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "_comment": "prebuild：在 build 前用 npm --prefix 安装 ../web，供 vue-tsc 解析 ../web/src（否则 TS2307）；不随 install 执行，仅 dev 时需自行在 web 装依赖或先 build。若要与 web 的 pnpm-lock 严格一致可另行 pnpm install。packageManager：与 web 一致，便于 Corepack / CI。hub/public 下 PWA 用 PNG/ico 与 web/public 同名资源一致，为拷贝；更新主站图标后可从 web/public 再 cp 覆盖。",
  "scripts": {
    "dev": "vite",
    "generate:seo-assets": "node ./scripts/generate-seo-assets.mjs",
    "prebuild": "pnpm run generate:seo-assets && npm install --prefix ../web",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/markdown-it": "^14.1.2",
    "@unocss/preset-wind4": "^66.6.8",
    "@vueuse/core": "^14.3.0",
    "floating-vue": "^5.2.2",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "photoswipe": "^5.4.4",
    "sass-embedded": "^1.99.0",
    "unocss": "^66.6.8",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^3.2.8"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "vite-plugin-pwa>vite": "8"
      }
    },
    "overrides": {
      "serialize-javascript@<7.0.5": "^7.0.5"
    }
  }
}
